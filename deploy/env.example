DIRECTIONAL_LATENCY_BUFFER=0.003
DIRECTIONAL_SETTLEMENT_BUFFER=0.002
SHADOW_PROFIT_EXIT_MIN_PNL=0.10
SHADOW_PROFIT_EXIT_BUFFER_PER_SHARE=0.001
LOTTERY_MIN_PRICE=0.01
LOTTERY_MAX_PRICE=0.05
LOTTERY_MIN_NET_EV=0.015
LOTTERY_MODEL_BUFFER=0.01
LOTTERY_EXECUTION_BUFFER=0.005
