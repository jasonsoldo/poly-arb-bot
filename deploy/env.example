PAIRED_MIN_LOCKED_ROI=0.001
DIRECTIONAL_MIN_NET_EV=0.015
DIRECTIONAL_MIN_PROBABILITY=0.90
# Shadow calibration evaluates all active seconds. Set to 1 for terminal-only entry gating.
DIRECTIONAL_ENFORCE_TIME_WINDOW=0
