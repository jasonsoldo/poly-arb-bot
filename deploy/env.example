MAKER_ACCUMULATE_MAX_DAILY_LOSS=5
MAKER_ACCUMULATE_MAX_CONSECUTIVE_ORPHANS=3
# --- maker 准入门槛（2026-07-21 按 VPS 6 小时实测定标） ---
# 单腿原始簿龄上限。实测盘口更新间隔：5m p50=133ms / 15m p50=1.07s /
# 1h p50=2.6s / 4h p50=35s；旧默认 750ms 对 15m+ 结构性过紧（46% 拒绝）。
MAKER_ACCUMULATE_MAX_BOOK_AGE_MS=2000
# 双腿簿龄差上限（配合放宽后的簿龄阈值）
MAKER_ACCUMULATE_MAX_BOOK_SKEW_MS=1000
# 时间窗口上限设为 2x 市场长度，覆盖 current + next 窗口；
# 旧默认等于市场寿命，导致全部 next 市场恒被排除（实测窗口通过率 13.6% -> 87.1%）。
# force_flatten 平仓下限不受影响，安全纪律不变。
MAKER_ACCUMULATE_WINDOW_MAX_5M=600
MAKER_ACCUMULATE_WINDOW_MAX_15M=1800
MAKER_ACCUMULATE_WINDOW_MAX_1H=7200
MAKER_ACCUMULATE_WINDOW_MAX_4H=28800
# 最小簿深度。旧默认 10 与深度代理口径（可成交深度 ~5）不匹配。
MAKER_ACCUMULATE_MIN_BOOK_DEPTH=5
