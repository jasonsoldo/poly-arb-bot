[Unit]
Description=Poly Arb Bot web monitor
After=network-online.target poly-arb-bot.service
Wants=network-online.target
# Bounded restart: give up after 10 restarts in 5 minutes instead of an
# uncontrolled restart loop (recover with: systemctl reset-failed poly-arb-web).
StartLimitIntervalSec=300
StartLimitBurst=10

[Service]
Type=simple
WorkingDirectory=/opt/poly-arb-bot
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/poly-arb-bot/.venv/bin/python -m poly_arb_bot.cli web-monitor --host 0.0.0.0 --port 8787 --log-file /opt/poly-arb-bot/logs/shadow-audit.jsonl --state-file /opt/poly-arb-bot/state/orders.json
Restart=always
RestartSec=5
StandardOutput=append:/var/log/poly-arb-web.log
StandardError=append:/var/log/poly-arb-web.err.log

[Install]
WantedBy=multi-user.target
